# MongoDB Config
MONGODB_INITDB_ROOT_USERNAME=admin
MONGODB_INITDB_ROOT_PASSWORD=
MONGODB_INITDB_DATABASE=blog_db

# MySQL Config
MYSQL_ROOT_PASSWORD=
